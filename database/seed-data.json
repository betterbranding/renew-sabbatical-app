{
  "app": {
    "name": "RE:NEW",
    "tagline": "A Personal Sabbatical Framework",
    "description": "A recurring 2-day personal sabbatical retreat designed for spiritual renewal, goal setting, and life alignment across 5 key areas: Mental, Physical, Relational, Financial, and Spiritual.",
    "anchorVerse": "Where there is no counsel, the people fall; But in the multitude of counselors there is safety. \u2014 Proverbs 11:14",
    "design": {
      "colorScheme": {
        "primary": "#0A1628",
        "secondary": "#1B3A5C",
        "accent": "#5BA4E6",
        "background": "#FFFFFF",
        "cardBackground": "#0A1628",
        "cardText": "#FFFFFF",
        "cardHeadline": "#FFFFFF"
      },
      "typography": {
        "headlineFont": "Helvetica Neue, Helvetica, Arial, sans-serif",
        "bodyFont": "Helvetica Neue, Helvetica, Arial, sans-serif",
        "headlineWeight": "700",
        "bodyWeight": "400"
      },
      "cardStyle": "Solid dark background with bold white headline text and white readable subtext",
      "animations": "Smooth page transitions, card entrance animations, scroll-triggered reveals, subtle hover effects"
    }
  },
  "schema": {
    "sessions": {
      "id": "string (UUID)",
      "title": "string",
      "date": "ISO date string",
      "status": "completed | in-progress | new"
