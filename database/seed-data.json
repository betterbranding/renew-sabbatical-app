  "day1Process": {
    "description": "Keys to the Kingdom - A guided spiritual process for Day 1 of each RE:NEW session",
    "steps": [
      {
        "order": 1,
        "name": "Reverence",
        "tags": [
          "Acknowledge"
        ],
        "suggestedTime": "10 mins",
        "description": "Begin with acknowledging God's presence and sovereignty."
      },
      {
        "order": 2,
        "name": "Release",
        "tags": [
          "Confession",
          "Forgiveness"
        ],
        "suggestedTime": "30 mins",
        "description": "Confess and release through forgiveness."
      },
      {
        "order": 3,
        "name": "Repent",
        "tags": [
          "Repent",
          "Renounce"
        ],
        "suggestedTime": "",
        "description": "Repent and renounce things that don't align with your values."
      },
      {
        "order": 4,
        "name": "Respond",
        "tags": [
          "Journal",
          "Seek"
        ],
        "suggestedTime": "",
        "description": "Journal your responses and seek direction."
      },
      {
        "order": 5,
        "name": "Receive",
        "tags": [
          "Soak",
          "Hear",
          "Journal",
          "Confirm"
        ],
        "suggestedTime": "1-2 hours",
        "description": "Soak in God's presence, hear, journal, and confirm what you receive."
      }
    ]
  },
  "day2Sections": {
    "hi5Health": {
      "description": "Assessment of 5 key health areas as preparation and alignment",
      "areas": [
        "Spiritual Health",
        "Mental Health",
        "Physical Health",
        "Relational Health",
        "Financial Health"
      ],
      "tags": [
        "Preparation",
        "Alignment"
      ]
    },
    "highFiveGoals": {
      "description": "One big 'Stake in the Ground' goal per life area - a declaration to improve",
      "categories": [
        "Mental",
        "Physical",
        "Relational",
        "Financial",
        "Spiritual"
      ],
      "fields": [
        "name",
        "tag",
        "dueDate",
        "completed"
      ]
    },
    "highFivePeople": {
      "description": "One accountability person per health area",
      "categories": [
        "Mental Health",
        "Spiritual Health",
        "Physical Health",
        "Relational Health",
        "Financial Health"
      ],
      "fields": [
        "name",
        "tag",
        "contacted"
      ]
    },
    "reflections": {
      "prompts": [
        "How will I feel if I accomplish my High Five goals?",
        "What will happen if I don't accomplish my High Five?"
      ]
    }
  }
}