        "Repent",
        "Renounce",
        "Seek",
        "Acknowledge",
        "Worship",
        "Soak",
        "Hear",
        "Confirm"
      ],
      "time": "string",
      "content": "string (user's written entry)"
    },
    "hi5Health": {
      "id": "string (UUID)",
      "sessionId": "string (FK)",
      "name": "string (Spiritual Health, Relational Health, Financial Health, Mental Health, Physical Health)",
      "tags": [
        "Preparation",
        "Alignment"
